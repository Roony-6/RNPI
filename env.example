# Copia este archivo como .env y ajusta los valores

# Cadena de conexión a PostgreSQL
# Formato: postgresql://usuario:contraseña@host:puerto/nombre_bd
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rnpi

# Clave secreta para firmar los JWT (usa una cadena larga y aleatoria en producción)
# Puedes generar una con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia-esta-clave-secreta-en-produccion

# Duración del token en minutos (480 = 8 horas)
TOKEN_EXPIRE_MINUTES=480
