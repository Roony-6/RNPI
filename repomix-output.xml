from main import SessionLocal, Personal, hash_password

def resetear_password():
    db = SessionLocal()
    # Buscamos al director
    admin = db.query(Personal).filter(Personal.correo == "director@rnpi.gob.mx").first()
    
    if admin:
        # Forzamos la nueva contraseña ENCRIPTADA
