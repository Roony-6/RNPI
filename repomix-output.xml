// 2. BUSCADOR CIE-10 (NUEVO)
// ==========================================

let cie10Timeout  = null;   // debounce
let cie10Selected = 0;      // índice del ítem resaltado con teclado

/**
 * Se llama con cada tecla en el input del buscador.
 * Espera 350 ms después de que el usuario para de escribir antes de consultar.
 */
function cie10Buscar(q) {
  clearTimeout(cie10Timeout);
  const lista = document.getElementById('cie10-results');

  // Si el campo está vacío, cerrar lista y resetear selección
  if (!q || q.trim().length < 2) {
    lista.innerHTML = '';
    lista.classList.remove('show');
    return;
  }

  // Mostrar spinner, ocultar lupa
  document.getElementById('cie10-icon').style.display    = 'none';
  document.getElementById('cie10-spinner').style.display = 'block';

  cie10Timeout = setTimeout(async () => {
    try {
      const res = await fetch(`${API}/catalogos/cie10_buscar?q=${encodeURIComponent(q.trim())}`);
      const data = await res.json();
      cie10RenderLista(data);
    } catch {
      cie10RenderLista([]);
    } finally {
      document.getElementById('cie10-icon').style.display    = 'flex';
      document.getElementById('cie10-spinner').style.display = 'none';
    }
  }, 350);
}

/** Dibuja los resultados en el <ul> */
function cie10RenderLista(items) {
  const lista = document.getElementById('cie10-results');
  cie10Selected = -1;

  if (!items.length) {
    lista.innerHTML = `<li class="cie10-empty">Sin resultados para esta búsqueda</li>`;
    lista.classList.add('show');
    return;
  }

  lista.innerHTML = items.map((item, i) => `
    <li role="option" tabindex="-1"
        onmousedown="cie10Elegir('${esc(item.codigo_subcategoria)}', '${esc(item.descripcion)}')"
        onmouseover="cie10Hover(${i})">
      <span class="cie10-code">${esc(item.codigo_subcategoria)}</span>
      <span class="cie10-desc">${esc(item.descripcion)}</span>
    </li>
  `).join('');
  lista.classList.add('show');
}

/** Navegación por teclado (↑ ↓ Enter Escape) */
function cie10KeyNav(e) {
  const lista = document.getElementById('cie10-results');
  const items = lista.querySelectorAll('li:not(.cie10-empty)');

  if (!lista.classList.contains('show') || !items.length) return;

  if (e.key === 'ArrowDown') {
    e.preventDefault();
    cie10Selected = Math.min(cie10Selected + 1, items.length - 1);
    cie10ResaltarActivo(items);
  } else if (e.key === 'ArrowUp') {
    e.preventDefault();
    cie10Selected = Math.max(cie10Selected - 1, 0);
    cie10ResaltarActivo(items);
  } else if (e.key === 'Enter' && cie10Selected >= 0) {
    e.preventDefault();
    items[cie10Selected].dispatchEvent(new Event('mousedown'));
  } else if (e.key === 'Escape') {
    lista.classList.remove('show');
  }
}

function cie10Hover(idx) {
  cie10Selected = idx;
  const items = document.querySelectorAll('#cie10-results li:not(.cie10-empty)');
  cie10ResaltarActivo(items);
}

function cie10ResaltarActivo(items) {
  items.forEach((li, i) => li.classList.toggle('cie10-active', i === cie10Selected));
}

/** El usuario seleccionó una enfermedad */
function cie10Elegir(codigo, descripcion) {
  // Guardar el código en el campo hidden que usará guardarExpediente()
  document.getElementById('f-tutor-cie10').value = codigo;

  // Limpiar input de búsqueda y cerrar lista
  document.getElementById('f-cie10-input').value = '';
  document.getElementById('cie10-results').classList.remove('show');

  // Mostrar chip con la selección
  document.getElementById('cie10-chip-label').textContent = `${codigo} — ${descripcion}`;
  document.getElementById('cie10-chip').classList.add('show');
}

/** Quitar la selección actual */
function cie10Limpiar() {
  document.getElementById('f-tutor-cie10').value      = 'NINGUNA';
  document.getElementById('cie10-chip-label').textContent = '';
  document.getElementById('cie10-chip').classList.remove('show');
  document.getElementById('f-cie10-input').value      = '';
  document.getElementById('f-cie10-input').focus();
}

/** Cerrar la lista si el usuario hace clic fuera del buscador */
document.addEventListener('click', (e) => {
  if (!document.getElementById('cie10-wrap').contains(e.target)) {
    document.getElementById('cie10-results').classList.remove('show');
  }
});


