```bash
sudo -u postgres pg_dump -d rnpi \
  --table=public.cat_cie_capitulo \
  --table=public.cat_cie_bloque \
  --table=public.cat_cie_categoria \
  --table=public.cat_cie_subcategoria \
  --inserts -f respaldo_catalogo_cie10.sql
