    /* ─── Formularios ─── */
    .form-group { margin-bottom: 1.15rem; }
    label { display: block; font-size: .82rem; font-weight: 600; color: var(--muted); margin-bottom: .4rem; text-transform: uppercase; }
    input[type=text], input[type=email], input[type=password], input[type=date], select { width: 100%; padding: .6rem .9rem; border: 1px solid var(--border); border-radius: 8px; font-family: inherit; font-size: .9rem; background: #fff; }
    input:focus, select:focus { outline: none; border-color: var(--teal); box-shadow: 0 0 0 3px rgba(14,116,144,.12); }
    .form-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1rem; }
    .span-2 { grid-column: span 2; }
    .field-error { font-size: .78rem; color: var(--red); margin-top: .3rem; display: none; }
    .section-title { font-size: 1rem; font-weight: 600; color: var(--teal); margin: 1.5rem 0 1rem; border-bottom: 2px solid #e2e8f0; padding-bottom: .4rem; }
    .section-title:first-child { margin-top: 0; }

    /* ─── Modales ─── */
    .overlay { position: fixed; inset: 0; background: rgba(0,0,0,.45); backdrop-filter: blur(2px); z-index: 200; display: none; align-items: center; justify-content: center; padding: 1rem; }
    .overlay.open { display: flex; animation: fadeIn .2s ease both; }
    .modal { background: var(--card); border-radius: 14px; width: 100%; max-width: 560px; max-height: 90vh; overflow-y: auto; box-shadow: 0 20px 60px rgba(0,0,0,.3); }
    .modal-wide { max-width: 850px; }
    .modal-header { padding: 1.5rem 1.75rem 1rem; display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid var(--border); }
    .modal-header h2 { font-family: 'DM Serif Display', serif; font-size: 1.3rem; color: var(--navy); }
    .modal-body { padding: 1.5rem 1.75rem; }
    .modal-footer { padding: 1rem 1.75rem 1.5rem; display: flex; justify-content: flex-end; gap: .75rem; border-top: 1px solid var(--border); }
    .close-btn { width: 30px; height: 30px; border-radius: 6px; border: 1px solid var(--border); background: #fff; cursor: pointer; display: grid; place-items: center; color: var(--muted); transition: all .15s; }
    .close-btn:hover { border-color: #999; color: var(--text); }

    /* ─── Vista Detalle (Expediente y Personal) ─── */
    .detail-card { background: #f8fafc; border: 1px solid var(--border); border-radius: 8px; padding: 1.25rem; margin-bottom: 1rem; }
    .detail-card h3 { font-size: .95rem; color: var(--navy); margin-bottom: 1rem; text-transform: uppercase; letter-spacing: .05em; }
    .detail-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem 2rem; }
    .detail-item label { font-size: .75rem; font-weight: 600; color: var(--muted); text-transform: uppercase; display: block; margin-bottom: .2rem; }
    .detail-item p { font-size: .95rem; color: var(--text); }
    .detail-sep { grid-column: 1/-1; border: none; border-top: 1px solid var(--border); }
    
    .avatar-row { display: flex; align-items: center; gap: 1rem; margin-bottom: 1.5rem; }
    .avatar { width: 56px; height: 56px; border-radius: 50%; background: var(--navy); color: var(--teal-l); display: grid; place-items: center; font-family: 'DM Serif Display', serif; font-size: 1.4rem; flex-shrink: 0; }

    /* ─── Modal Confirmación ─── */
    .confirm-icon { width: 56px; height: 56px; border-radius: 50%; display: grid; place-items: center; margin: 0 auto 1rem; }
    .confirm-icon.danger { background: #fee2e2; color: var(--red); }
    .confirm-icon.warning { background: #fef3c7; color: var(--amber); }
    #confirm-modal .modal-body { text-align: center; }
    #confirm-modal h3 { font-family: 'DM Serif Display', serif; font-size: 1.2rem; margin-bottom: .5rem; }
    #confirm-modal p  { color: var(--muted); font-size: .9rem; line-height: 1.5; }

    /* Toasts y Utilidades */
    #toast-container { position: fixed; bottom: 1.5rem; right: 1.5rem; z-index: 999; display: flex; flex-direction: column; gap: .5rem; }
    .toast { padding: .75rem 1.25rem; border-radius: 10px; font-size: .875rem; color: #fff; max-width: 320px; animation: slideInRight .3s ease, fadeOut .4s ease 3s both; box-shadow: 0 4px 20px rgba(0,0,0,.2); }
    .toast.success { background: var(--green); }
    .toast.error   { background: var(--red); }
    .toast.info    { background: var(--teal); }

    @keyframes fadeIn { from { opacity: 0 } to { opacity: 1 } }
    @keyframes slideInRight { from { opacity: 0; transform: translateX(40px) } to { opacity: 1; transform: none } }
    @keyframes fadeOut { from { opacity: 1 } to { opacity: 0; pointer-events: none } }

    /* ══════════════════════════════════════════
       ─── Buscador CIE-10 (NUEVO) ───
       ══════════════════════════════════════════ */
    .cie10-wrap {
      position: relative;
    }
    .cie10-wrap input[type=text] {
      width: 100%;
      padding: .6rem 2.6rem .6rem .9rem;
      border: 1px solid var(--border);
      border-radius: 8px;
      font-family: inherit;
      font-size: .9rem;
      background: #fff;
      transition: border-color .2s;
    }
    .cie10-wrap input[type=text]:focus {
      outline: none;
      border-color: var(--teal);
      box-shadow: 0 0 0 3px rgba(14,116,144,.12);
    }
    /* Icono lupa dentro del input */
    .cie10-wrap .cie10-icon {
      position: absolute;
      right: .75rem;
      top: 50%;
      transform: translateY(-50%);
      color: var(--muted);
      pointer-events: none;
      display: flex;
      align-items: center;
    }
    /* Spinner de carga */
    .cie10-wrap .cie10-spinner {
      position: absolute;
      right: .75rem;
      top: 50%;
      transform: translateY(-50%);
      display: none;
    }
    .cie10-spinner::after {
      content: '';
      display: block;
      width: 16px; height: 16px;
      border: 2px solid var(--border);
      border-top-color: var(--teal);
      border-radius: 50%;
      animation: spin .6s linear infinite;
    }
    @keyframes spin { to { transform: rotate(360deg); } }

    /* Lista desplegable de resultados */
    .cie10-results {
      position: absolute;
      top: calc(100% + 4px);
      left: 0; right: 0;
      background: #fff;
      border: 1px solid var(--border);
      border-radius: 8px;
      box-shadow: 0 8px 24px rgba(13,31,60,.14);
      z-index: 300;
      max-height: 240px;
      overflow-y: auto;
      display: none;
    }
    .cie10-results.show { display: block; }
    .cie10-results li {
      list-style: none;
      padding: .55rem .9rem;
      cursor: pointer;
      font-size: .875rem;
      display: flex;
      align-items: baseline;
      gap: .6rem;
      border-bottom: 1px solid #f1f5f9;
      transition: background .12s;
    }
    .cie10-results li:last-child { border-bottom: none; }
    .cie10-results li:hover,
    .cie10-results li.cie10-active { background: #ecfeff; }
    .cie10-results li .cie10-code {
      font-size: .75rem;
      font-weight: 700;
      color: var(--teal);
      min-width: 52px;
      flex-shrink: 0;
    }
    .cie10-results li .cie10-desc {
      color: var(--text);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .cie10-results li.cie10-empty {
      color: var(--muted);
      cursor: default;
      font-style: italic;
      justify-content: center;
    }
    .cie10-results li.cie10-empty:hover { background: transparent; }

    /* Chip de selección: aparece cuando el usuario elige una enfermedad */
    .cie10-chip {
      display: none;
      align-items: center;
      gap: .5rem;
      margin-top: .5rem;
      background: #ecfeff;
      border: 1px solid #a5f3fc;
      border-radius: 20px;
      padding: .3rem .75rem;
      font-size: .8rem;
      color: #0f766e;
      width: fit-content;
    }
    .cie10-chip.show { display: inline-flex; }
    .cie10-chip button {
      background: none; border: none; cursor: pointer;
      color: #0f766e; font-size: .9rem; line-height: 1;
      padding: 0; margin-left: .2rem;
    }
    .cie10-chip button:hover { color: var(--red); }
  </style>
</head>
