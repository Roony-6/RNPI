const API = 'http://localhost:8000';
let TOKEN       = localStorage.getItem('rnpi_token') || '';
let USUARIO     = JSON.parse(localStorage.getItem('rnpi_user') || 'null');
let ROLES       = [];
let PERSONAL_ALL = [];

async function apiFetch(path, opts = {}) {
  const headers = { 'Content-Type': 'application/json' };
  if (TOKEN) headers['Authorization'] = `Bearer ${TOKEN}`;
  const res = await fetch(API + path, { ...opts, headers: { ...headers, ...opts.headers } });
  if (res.status === 401) { logout(); return null; }
  return res;
}

async function login() {
  const correo = document.getElementById('l-correo').value.trim();
  const pass   = document.getElementById('l-pass').value;
  if (!correo || !pass) {
    document.getElementById('login-error').style.display = 'block';
    document.getElementById('login-error').innerText = 'Llene los campos';
    return;
  }
  const body = new URLSearchParams({ username: correo, password: pass });
  try {
    const res = await fetch(API + '/auth/login', { method: 'POST', headers: { 'Content-Type': 'application/x-www-form-urlencoded' }, body });
    if (!res.ok) throw new Error("Credenciales incorrectas");
    const data = await res.json();
    TOKEN = data.access_token; USUARIO = data.usuario;
    localStorage.setItem('rnpi_token', TOKEN); localStorage.setItem('rnpi_user', JSON.stringify(USUARIO));
    iniciarApp();
  } catch(e) {
    document.getElementById('login-error').style.display = 'block';
    document.getElementById('login-error').innerText = e.message;
  }
}

function logout() {
  TOKEN = ''; USUARIO = null;
  localStorage.removeItem('rnpi_token'); localStorage.removeItem('rnpi_user');
  document.getElementById('screen-main').style.display  = 'none';
  document.getElementById('screen-login').style.display = 'flex';
}

function iniciarApp() {
  document.getElementById('screen-login').style.display = 'none';
  document.getElementById('screen-main').style.display  = 'block';
  document.getElementById('header-username').textContent = USUARIO ? USUARIO.nombre_completo : 'Usuario';
  cargarCatalogosNNA();
  cargarExpedientes();
  cargarRoles();
  cargarPersonal();
}

if (TOKEN) iniciarApp();

