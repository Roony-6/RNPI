<file path="main.py">
"""
RNPI — Red Nacional de Protección Infantil
Backend principal: FastAPI + SQLAlchemy + PostgreSQL
"""

import os
from datetime import datetime, timedelta, timezone
from typing import Optional

from dotenv import load_dotenv
from fastapi import Depends, FastAPI, HTTPException, status
from fastapi.middleware.cors import CORSMiddleware
from fastapi.security import OAuth2PasswordBearer, OAuth2PasswordRequestForm
from jose import JWTError, jwt
from passlib.context import CryptContext
from pydantic import BaseModel, EmailStr
from sqlalchemy import Boolean, Column, Integer, String, Date, Text, ForeignKey, DateTime, create_engine, text
from sqlalchemy.sql import func
from sqlalchemy.orm import DeclarativeBase, Session, sessionmaker, relationship
from fastapi.staticfiles import StaticFiles
from fastapi.responses import FileResponse

load_dotenv()

DATABASE_URL = os.getenv(
    "DATABASE_URL",
    "postgresql://postgres:1234@localhost:5432/rnpi"
)
SECRET_KEY    = os.getenv("SECRET_KEY", "cambia-esta-clave-secreta-en-produccion")
ALGORITHM     = "HS256"
TOKEN_MINUTES = int(os.getenv("TOKEN_EXPIRE_MINUTES", "480"))   # 8 horas

engine = create_engine(DATABASE_URL, pool_pre_ping=True)
SessionLocal = sessionmaker(bind=engine, autoflush=False, autocommit=False)


class Base(DeclarativeBase):
    pass


def get_db():
    """Dependencia: sesión de BD por petición."""
    db = SessionLocal()
    try:
        yield db
    finally:
        db.close()

# ==========================================
# MODELOS DE LA BASE DE DATOS
# ==========================================

class Personal(Base):
    __tablename__ = "personal"

    id_personal     = Column(Integer, primary_key=True, index=True)
    nombre_completo = Column(String(200), nullable=False)
    rfc             = Column(String(13),  nullable=False, unique=True)
    curp            = Column(String(18),  nullable=False, unique=True)
    correo          = Column(String(150), nullable=False, unique=True)
    contrasena      = Column(String,      nullable=False)
    activo          = Column(Boolean,     default=True,   nullable=False)
    id_rol          = Column(Integer,     nullable=False)


class CatRol(Base):
    __tablename__ = "cat_roles"

    id_rol     = Column(Integer, primary_key=True, index=True)
    nombre_rol = Column(String(80), nullable=False)


class CatLenguaInali(Base):
    __tablename__ = "cat_lengua_inali"

    id_lengua   = Column(Integer,     primary_key=True, index=True)
    nombre      = Column(String(100), nullable=False)
    es_indigena = Column(Boolean,     default=True)


class CatEstado(Base):
    __tablename__ = "cat_estados"

    id_estado = Column(Integer,     primary_key=True, index=True)
    nombre    = Column(String(100), nullable=False)


class CatMunicipio(Base):
    __tablename__ = "cat_municipios"

    id_municipio = Column(Integer,     primary_key=True, index=True)
    id_estado    = Column(Integer,     ForeignKey("cat_estados.id_estado"), nullable=False)
    nombre       = Column(String(150), nullable=False)


class CatCieSubcategoria(Base):
    __tablename__ = "cat_cie_subcategoria"

    id_subcategoria = Column(Integer,     primary_key=True, index=True)
    id_categoria    = Column(Integer,     nullable=False)
    codigo          = Column(String(7),   unique=True, nullable=False)
    descripcion     = Column(String(300))


class Tutor(Base):
    __tablename__ = "tutores"

    id_tutor        = Column(Integer,   primary_key=True, index=True)
    nombre_completo = Column(String(200), nullable=False)
    curp            = Column(String(18),  unique=True, index=True)
    telefono        = Column(String(20))
    fecha_registro  = Column(DateTime,  server_default=func.now())

    # Relaciones
    menores      = relationship("Menor",          back_populates="tutor")
    enfermedades = relationship("TutorEnfermedad", back_populates="tutor")


class Menor(Base):
    __tablename__ = "nna"

    id_menor          = Column(Integer,    primary_key=True, index=True)
    nombre            = Column(String(100), nullable=False)
    apellido_paterno  = Column(String(100), nullable=False)
    apellido_materno  = Column(String(100))
    id_tutor          = Column(Integer,    ForeignKey("tutores.id_tutor"))
    id_lengua         = Column(Integer,    ForeignKey("cat_lengua_inali.id_lengua"))
    id_municipio      = Column(Integer,    ForeignKey("cat_municipios.id_municipio"))

    # Relaciones bidireccionales
    tutor             = relationship("Tutor",         back_populates="menores")
    hechos_victimales = relationship("HechoVictimal", back_populates="menor")


class HechoVictimal(Base):
    __tablename__ = "hechos_victimales"

    id_hecho              = Column(Integer,   primary_key=True, index=True)
    id_menor              = Column(Integer,   ForeignKey("nna.id_menor", ondelete="CASCADE"), nullable=False)
    nombre_victima_madre  = Column(String(200), nullable=False)
    fecha_hecho           = Column(Date)
    expediente_juridico   = Column(String(100))
    descripcion_delito    = Column(Text)

    # Relaciones
    menor = relationship("Menor", back_populates="hechos_victimales")


# ─── CORRECCIÓN 3-A: FK ahora apunta a id_subcategoria (Integer) en lugar de codigo_subcategoria ───
class TutorEnfermedad(Base):
    __tablename__ = "tutor_enfermedad"

    id_tutor_enfermedad   = Column(Integer, primary_key=True, index=True)
    id_tutor              = Column(Integer, ForeignKey("tutores.id_tutor",                          ondelete="CASCADE"), nullable=False)
    id_subcategoria_cie10 = Column(Integer, ForeignKey("cat_cie_subcategoria.id_subcategoria"),      nullable=False)   # ← Integer, no String
    es_cronica            = Column(Boolean, default=False)
    esta_controlada       = Column(Boolean, default=False)

    # Relaciones
    tutor = relationship("Tutor", back_populates="enfermedades")


# ==========================================
# CONFIGURACIÓN DE SEGURIDAD Y AUTENTICACIÓN
# ==========================================

pwd_ctx = CryptContext(schemes=["bcrypt"], deprecated="auto")
oauth2  = OAuth2PasswordBearer(tokenUrl="/auth/login")


def hash_password(plain: str) -> str:
    return pwd_ctx.hash(plain)


def verify_password(plain: str, hashed: str) -> bool:
    return pwd_ctx.verify(plain, hashed)


def crear_token(data: dict) -> str:
    payload = data.copy()
    payload["exp"] = datetime.now(timezone.utc) + timedelta(minutes=TOKEN_MINUTES)
    return jwt.encode(payload, SECRET_KEY, algorithm=ALGORITHM)


def usuario_actual(token: str = Depends(oauth2), db: Session = Depends(get_db)) -> Personal:
    credencial_error = HTTPException(
        status_code=status.HTTP_401_UNAUTHORIZED,
        detail="No autenticado o token expirado",
        headers={"WWW-Authenticate": "Bearer"},
    )
    try:
        payload = jwt.decode(token, SECRET_KEY, algorithms=[ALGORITHM])
        id_personal: int = int(payload.get("sub", 0))
    except (JWTError, ValueError):
        raise credencial_error

    usuario = db.get(Personal, id_personal)
    if not usuario or not usuario.activo:
        raise credencial_error
    return usuario


def solo_director(usuario: Personal = Depends(usuario_actual), db: Session = Depends(get_db)) -> Personal:
    """Restringe el acceso a roles con id_rol 1 (Director) o 2 (Coordinador)."""
    rol = db.get(CatRol, usuario.id_rol)
    nombre = rol.nombre_rol.lower() if rol else ""
    if not any(x in nombre for x in ("director", "coordinador")):
        raise HTTPException(
            status_code=status.HTTP_403_FORBIDDEN,
            detail="No tiene permisos para realizar esta acción",
        )
    return usuario


# ==========================================
# ESQUEMAS PYDANTIC (Para validación de datos)
# ==========================================

class PersonalBase(BaseModel):
    nombre_completo: str
    rfc:             str
    curp:            str
    correo:          EmailStr
    id_rol:          int

class PersonalCrear(PersonalBase):
    contrasena: str

class PersonalActualizar(PersonalBase):
    pass

class PersonalRespuesta(PersonalBase):
    id_personal: int
    activo:      bool
    model_config = {"from_attributes": True}

class AccesoActualizar(BaseModel):
    activo: bool

class RolRespuesta(BaseModel):
    id_rol:     int
    nombre_rol: str
    model_config = {"from_attributes": True}

class TokenRespuesta(BaseModel):
    access_token: str
    token_type:   str
    usuario:      PersonalRespuesta


# ==========================================
# CONFIGURACIÓN DE FASTAPI Y RUTAS
# ==========================================

app = FastAPI(
    title="RNPI API",
    description="Red Nacional de Protección Infantil — Backend",
    version="1.0.0",
)

app.add_middleware(
    CORSMiddleware,
    allow_origins=[
        "http://localhost:8000",
        "http://127.0.0.1:8000"
    ],
    allow_credentials=True,
    allow_methods=["*"],
    allow_headers=["*"],
)

app.mount("/static", StaticFiles(directory="static"), name="static")

@app.get("/ui", tags=["Frontend"])
def frontend():
    return FileResponse("static/index.html")

@app.get("/", tags=["Sistema"])
def raiz():
    return {"mensaje": "RNPI API activa"}

@app.get("/health", tags=["Sistema"])
def health(db: Session = Depends(get_db)):
    """Verifica la conexión a la base de datos."""
    try:
        db.execute(text("SELECT 1"))
        return {"estado": "ok", "base_de_datos": "conectada"}
    except Exception as e:
        raise HTTPException(status_code=503, detail=f"Base de datos no disponible: {e}")

@app.post("/auth/login", response_model=TokenRespuesta, tags=["Autenticación"])
def login(form: OAuth2PasswordRequestForm = Depends(), db: Session = Depends(get_db)):
    """
    Inicia sesión con correo (campo username) y contraseña.
    Devuelve un JWT Bearer y los datos básicos del usuario.
    """
    usuario = db.query(Personal).filter(Personal.correo == form.username).first()

    if not usuario or not verify_password(form.password, usuario.contrasena):
        raise HTTPException(
            status_code=status.HTTP_401_UNAUTHORIZED,
            detail="Correo o contraseña incorrectos",
            headers={"WWW-Authenticate": "Bearer"},
        )
    if not usuario.activo:
        raise HTTPException(
            status_code=status.HTTP_403_FORBIDDEN,
            detail="Su cuenta está inactiva. Contacte al administrador.",
        )

    token = crear_token({"sub": str(usuario.id_personal)})
    return {"access_token": token, "token_type": "bearer", "usuario": usuario}

@app.get("/cat_roles", response_model=list[RolRespuesta], tags=["Catálogos"])
def listar_roles(
    db: Session = Depends(get_db),
    _: Personal = Depends(usuario_actual),
):
    """Devuelve todos los roles disponibles."""
    return db.query(CatRol).order_by(CatRol.id_rol).all()

@app.get("/personal", response_model=list[PersonalRespuesta], tags=["Personal"])
def listar_personal(
    db: Session = Depends(get_db),
    _: Personal = Depends(usuario_actual),
):
    """Lista todo el personal registrado (requiere sesión activa)."""
    return db.query(Personal).order_by(Personal.id_personal).all()

@app.get("/personal/{id_personal}", response_model=PersonalRespuesta, tags=["Personal"])
def obtener_personal(
    id_personal: int,
    db: Session = Depends(get_db),
    _: Personal = Depends(usuario_actual),
):
    """Obtiene los datos de un miembro del personal por ID."""
    persona = db.get(Personal, id_personal)
    if not persona:
        raise HTTPException(status_code=404, detail="Personal no encontrado")
    return persona

@app.post("/personal", response_model=PersonalRespuesta, status_code=201, tags=["Personal"])
def registrar_personal(
    datos: PersonalCrear,
    db: Session = Depends(get_db),
    _: Personal = Depends(solo_director),
):
    """
    Registra nuevo personal.
    Solo accesible para Director o Coordinador.
    """
    if db.query(Personal).filter(Personal.correo == datos.correo).first():
        raise HTTPException(status_code=409, detail="Ya existe un registro con ese correo")
    if db.query(Personal).filter(Personal.rfc == datos.rfc).first():
        raise HTTPException(status_code=409, detail="Ya existe un registro con ese RFC")
    if db.query(Personal).filter(Personal.curp == datos.curp).first():
        raise HTTPException(status_code=409, detail="Ya existe un registro con esa CURP")
    if not db.get(CatRol, datos.id_rol):
        raise HTTPException(status_code=400, detail="El rol indicado no existe")

    nueva_persona = Personal(
        nombre_completo=datos.nombre_completo,
        rfc=datos.rfc.upper(),
        curp=datos.curp.upper(),
        correo=datos.correo,
        contrasena=hash_password(datos.contrasena),
        id_rol=datos.id_rol,
        activo=True,
    )
    db.add(nueva_persona)
    db.commit()
    db.refresh(nueva_persona)
    return nueva_persona

@app.put("/personal/{id_personal}", response_model=PersonalRespuesta, tags=["Personal"])
def actualizar_personal(
    id_personal: int,
    datos: PersonalActualizar,
    db: Session = Depends(get_db),
    _: Personal = Depends(solo_director),
):
    """
    Actualiza los datos de un miembro del personal (sin cambiar contraseña).
    Solo accesible para Director o Coordinador.
    """
    persona = db.get(Personal, id_personal)
    if not persona:
        raise HTTPException(status_code=404, detail="Personal no encontrado")

    dup_correo = db.query(Personal).filter(
        Personal.correo == datos.correo, Personal.id_personal != id_personal
    ).first()
    if dup_correo:
        raise HTTPException(status_code=409, detail="El correo ya está en uso por otro registro")

    dup_rfc = db.query(Personal).filter(
        Personal.rfc == datos.rfc, Personal.id_personal != id_personal
    ).first()
    if dup_rfc:
        raise HTTPException(status_code=409, detail="El RFC ya está en uso por otro registro")

    dup_curp = db.query(Personal).filter(
        Personal.curp == datos.curp, Personal.id_personal != id_personal
    ).first()
    if dup_curp:
        raise HTTPException(status_code=409, detail="La CURP ya está en uso por otro registro")

    if not db.get(CatRol, datos.id_rol):
        raise HTTPException(status_code=400, detail="El rol indicado no existe")

    persona.nombre_completo = datos.nombre_completo
    persona.rfc             = datos.rfc.upper()
    persona.curp            = datos.curp.upper()
    persona.correo          = datos.correo
    persona.id_rol          = datos.id_rol
    db.commit()
    db.refresh(persona)
    return persona

@app.patch("/personal/{id_personal}/acceso", response_model=PersonalRespuesta, tags=["Personal"])
def cambiar_acceso(
    id_personal: int,
    datos: AccesoActualizar,
    db: Session = Depends(get_db),
    director: Personal = Depends(solo_director),
):
    """
    Otorga o revoca el acceso al sistema de un miembro del personal.
    Solo accesible para Director o Coordinador.
    """
    persona = db.get(Personal, id_personal)
    if not persona:
        raise HTTPException(status_code=404, detail="Personal no encontrado")
    if persona.id_personal == director.id_personal:
        raise HTTPException(status_code=400, detail="No puede revocar su propio acceso")

    persona.activo = datos.activo
    db.commit()
    db.refresh(persona)
    return persona

@app.delete("/personal/{id_personal}", status_code=204, tags=["Personal"])
def eliminar_personal(
    id_personal: int,
    db: Session = Depends(get_db),
    director: Personal = Depends(solo_director),
):
    """
    Elimina el registro de un miembro del personal.
    Solo accesible para Director o Coordinador.
    """
    persona = db.get(Personal, id_personal)
    if not persona:
        raise HTTPException(status_code=404, detail="Personal no encontrado")
    if persona.id_personal == director.id_personal:
        raise HTTPException(status_code=400, detail="No puede eliminar su propio registro")

    db.delete(persona)
    db.commit()

