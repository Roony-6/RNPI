@app.post("/expedientes", status_code=201, tags=["Expedientes"])
def registrar_expediente(datos: ExpedienteCrear, db: Session = Depends(get_db)):
    # 1. Separar el nombre del menor
    partes = datos.nna_nombre.split()
    nom = partes[0] if partes else "Desconocido"
    ap  = partes[1] if len(partes) > 1 else ""
    am  = " ".join(partes[2:]) if len(partes) > 2 else ""

    # 2. Guardar Tutor
    tutor = Tutor(
        nombre_completo=datos.tutor_nombre,
        curp=datos.tutor_curp,
        telefono=datos.tutor_telefono
    )
    db.add(tutor)
    db.commit()
    db.refresh(tutor)

    # 3. Guardar Menor (enlazado al tutor)
    menor = Menor(
        nombre=nom, apellido_paterno=ap, apellido_materno=am,
        id_tutor=tutor.id_tutor,
        id_lengua=datos.lengua_id,
        id_municipio=datos.municipio_id,
    )
    db.add(menor)
    db.commit()
    db.refresh(menor)

    # 4. Guardar Hecho Victimal
    fecha_obj = datetime.strptime(datos.fecha_hecho, "%Y-%m-%d").date() if datos.fecha_hecho else None
    hecho = HechoVictimal(
        id_menor=menor.id_menor,
        nombre_victima_madre=datos.victima_madre,
        fecha_hecho=fecha_obj,
        expediente_juridico=datos.expediente_juridico,
        descripcion_delito=datos.delito
    )
    db.add(hecho)

    # ─── CORRECCIÓN 3-B: Busca el id entero por código antes de insertar la FK ───
    if datos.cie10_codigo and datos.cie10_codigo != "NINGUNA":
        sub = db.query(CatCieSubcategoria)\
                .filter(CatCieSubcategoria.codigo == datos.cie10_codigo)\
                .first()
        if sub:
            enf = TutorEnfermedad(
                id_tutor=tutor.id_tutor,
                id_subcategoria_cie10=sub.id_subcategoria,  # ← entero correcto
                es_cronica=True,
                esta_controlada=True
            )
            db.add(enf)

    db.commit()
    return {"mensaje": "Expediente guardado con éxito"}


@app.get("/expedientes", tags=["Expedientes"])
def listar_expedientes(db: Session = Depends(get_db)):
    menores   = db.query(Menor).all()
    resultado = []
    for m in menores:
        t   = m.tutor
        h   = m.hechos_victimales[0] if m.hechos_victimales else None
        enf = t.enfermedades[0]      if t and t.enfermedades else None

        # Recuperar el código CIE-10 legible si hay enfermedad registrada
        cie10_label = "Ninguna / Sano"
        if enf:
            sub = db.get(CatCieSubcategoria, enf.id_subcategoria_cie10)
            if sub:
                cie10_label = f"{sub.codigo} - {sub.descripcion}"

        lengua_nombre = "No especificado"
        if m.id_lengua:
            lng = db.get(CatLenguaInali, m.id_lengua)
            if lng:
                lengua_nombre = lng.nombre

        localidad_nombre = "No especificada"
        if m.id_municipio:
            mun = db.get(CatMunicipio, m.id_municipio)
            if mun:
                est = db.get(CatEstado, mun.id_estado)
                localidad_nombre = f"{mun.nombre}, {est.nombre}" if est else mun.nombre

        resultado.append({
            "id":       f"EXP-{m.id_menor:03d}",
            "nombre":   f"{m.nombre} {m.apellido_paterno} {m.apellido_materno}",
            "curp":     "Registrada en BD",
            "fecha_nac": "N/A",
            "idioma":   lengua_nombre,
            "localidad": localidad_nombre,
            "tutor": {
                "nombre":   t.nombre_completo if t else "Sin tutor",
                "telefono": t.telefono        if t else "",
                "cie10":    cie10_label
            },
            "hecho": {
                "exp":    h.expediente_juridico if h else "",
                "delito": h.descripcion_delito  if h else "",
                "madre":  h.nombre_victima_madre if h else ""
            },
            "estatus": "Proceso Activo",
            "badge":   "badge-teal",
            "fecha":   "Reciente"
        })
    return resultado


