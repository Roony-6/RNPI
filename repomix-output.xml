class ExpedienteCrear(BaseModel):
    nna_nombre:          str
    tutor_nombre:        str
    tutor_curp:          str
    tutor_telefono:      str
    cie10_codigo:        str
    victima_madre:       str
    fecha_hecho:         str
    expediente_juridico: str
    delito:              str
    lengua_id:           Optional[int] = None
