async function verDetallePersonal(id) {
  try {
    const res = await apiFetch(`/personal/${id}`); if (!res) return;
    const p = await res.json();
    const initials  = p.nombre_completo.split(' ').slice(0,2).map(w=>w[0]).join('').toUpperCase();
    const nombreRolStr = ROLES.find(r => r.id_rol == p.id_rol)?.nombre_rol || 'Rol';
    document.getElementById('det-avatar').textContent  = initials;
    document.getElementById('det-nombre').textContent  = p.nombre_completo;
    document.getElementById('det-badge').innerHTML     = `<span class="badge ${p.activo ? 'badge-green' : 'badge-red'}">${p.activo ? 'Activo' : 'Inactivo'}</span> <span class="badge badge-navy">${nombreRolStr}</span>`;
    document.getElementById('det-rfc').textContent     = p.rfc;
    document.getElementById('det-curp').textContent    = p.curp;
    document.getElementById('det-correo').textContent  = p.correo;
    document.getElementById('det-rol').textContent     = nombreRolStr;
    document.getElementById('det-activo').innerHTML    = p.activo ? '<span class="badge badge-green">Activo</span>' : '<span class="badge badge-red">Inactivo</span>';
    document.getElementById('det-id').textContent      = `#${p.id_personal}`;
    openModal('modal-detalle-personal');
  } catch(e) { toast('Error al cargar detalle', 'error'); }
}

function openModalNuevoPersonal() {
  document.getElementById('f-id').value       = '';
  document.getElementById('f-nombre').value   = '';
  document.getElementById('f-rfc').value      = '';
  document.getElementById('f-curp').value     = '';
  document.getElementById('f-correo').value   = '';
  document.getElementById('f-rol').value      = '';
  document.getElementById('wrap-password').style.display  = '';
  document.getElementById('wrap-password2').style.display = '';
  document.getElementById('modal-pers-title').innerText   = 'Registrar Personal';
  openModal('modal-form-personal');
}

function openModalEditarPersonal(id) {
  const p = PERSONAL_ALL.find(x => x.id_personal === id); if (!p) return;
  document.getElementById('f-id').value     = p.id_personal;
  document.getElementById('f-nombre').value = p.nombre_completo;
  document.getElementById('f-rfc').value    = p.rfc;
  document.getElementById('f-curp').value   = p.curp;
  document.getElementById('f-correo').value = p.correo;
  document.getElementById('f-rol').value    = p.id_rol;
  document.getElementById('wrap-password').style.display  = 'none';
  document.getElementById('wrap-password2').style.display = 'none';
  document.getElementById('modal-pers-title').innerText   = 'Editar Personal';
  openModal('modal-form-personal');
}

async function guardarPersonal() {
  const id   = document.getElementById('f-id').value;
  const body = {
    nombre_completo: document.getElementById('f-nombre').value,
    rfc:    document.getElementById('f-rfc').value,
    curp:   document.getElementById('f-curp').value,
    correo: document.getElementById('f-correo').value,
    id_rol: Number(document.getElementById('f-rol').value)
  };
  if (!id) body.contrasena = document.getElementById('f-password').value;

  const method = id ? 'PUT' : 'POST';
  const url    = id ? `/personal/${id}` : '/personal';
  try {
    const res = await apiFetch(url, { method, body: JSON.stringify(body) });
    if (!res.ok) throw new Error("Error al guardar");
    toast('Personal guardado exitosamente', 'success');
    closeModal('modal-form-personal');
    cargarPersonal();
  } catch(e) { toast('Error de validación', 'error'); }
}

function confirmarAcceso(id, activo) {
  const p      = PERSONAL_ALL.find(x => x.id_personal === id);
  const nombre = p ? p.nombre_completo : `#${id}`;
  if (activo) {
    mostrarConfirm({
      icon: 'warning', title: 'Revocar acceso',
      message: `¿Desea revocar el acceso al sistema de <strong>${esc(nombre)}</strong>? El registro se conservará pero no podrá iniciar sesión.`,
      btnClass: 'btn-warning', btnText: 'Revocar acceso',
      callback: () => toggleAcceso(id, false)
    });
  } else {
    mostrarConfirm({
      icon: 'success', title: 'Restaurar acceso',
      message: `¿Desea restaurar el acceso de <strong>${esc(nombre)}</strong>?`,
      btnClass: 'btn-success', btnText: 'Restaurar acceso',
      callback: () => toggleAcceso(id, true)
    });
  }
}

async function toggleAcceso(id, nuevoActivo) {
  try {
    const res = await apiFetch(`/personal/${id}/acceso`, { method: 'PATCH', body: JSON.stringify({ activo: nuevoActivo }) });
    if (!res.ok) throw new Error("Error al cambiar acceso");
    toast(nuevoActivo ? 'Acceso restaurado' : 'Acceso revocado', 'info');
    closeModal('confirm-modal-overlay');
    cargarPersonal();
  } catch(e) { toast('Error de conexión', 'error'); }
}

function confirmarEliminarPersonal(id) {
  const p      = PERSONAL_ALL.find(x => x.id_personal === id);
  const nombre = p ? p.nombre_completo : `#${id}`;
  mostrarConfirm({
    icon: 'danger', title: 'Eliminar registro de personal',
    message: `¿Está seguro de eliminar a <strong>${esc(nombre)}</strong>? Esta acción es irreversible.`,
    btnClass: 'btn-danger', btnText: 'Eliminar Personal',
    callback: () => eliminarPersonal(id)
  });
}

async function eliminarPersonal(id) {
  try {
    const res = await apiFetch(`/personal/${id}`, { method: 'DELETE' });
    if (!res.ok) throw new Error("Error al eliminar");
    toast('Registro eliminado exitosamente', 'success');
    closeModal('confirm-modal-overlay');
    cargarPersonal();
  } catch(e) { toast('Error de conexión', 'error'); }
}
</script>
