# ─── CORRECCIÓN 2: Endpoint corregido — usa los campos reales del modelo ───
@app.get("/catalogos/cie10_comunes", tags=["Catálogos"])
def obtener_cie10_comunes(db: Session = Depends(get_db)):
    """Devuelve las enfermedades más comunes del catálogo CIE-10 real."""
    from sqlalchemy import or_
    terminos = [
        "%diabetes%", "%hipertensi%", "%asma%", "%obesidad%",
        "%depresion%", "%epilepsia%", "%anemia%", "%artritis%",
        "%cancer%", "%cardio%"
    ]
    filtros = [CatCieSubcategoria.descripcion.ilike(t) for t in terminos]
    resultados = db.query(CatCieSubcategoria).filter(or_(*filtros)).limit(20).all()
    # Devuelve "codigo_subcategoria" para que el <select> del HTML lo use como value
    return [
        {"codigo_subcategoria": r.codigo, "descripcion": r.descripcion}
        for r in resultados
    ]


@app.get("/catalogos/cie10_buscar", tags=["Catálogos"])
def buscar_cie10(q: str = "", db: Session = Depends(get_db)):
    """
    Búsqueda en tiempo real del catálogo CIE-10.
    Acepta el parámetro ?q= y devuelve hasta 15 coincidencias
    buscando tanto en el código como en la descripción.
    """
    if not q or len(q.strip()) < 2:
        return []
    termino = f"%{q.strip()}%"
    resultados = (
        db.query(CatCieSubcategoria)
        .filter(
            CatCieSubcategoria.descripcion.ilike(termino)
            | CatCieSubcategoria.codigo.ilike(termino)
        )
        .order_by(CatCieSubcategoria.codigo)
        .limit(15)
        .all()
    )
    return [
        {"codigo_subcategoria": r.codigo, "descripcion": r.descripcion}
        for r in resultados
    ]


