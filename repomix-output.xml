let EXPEDIENTES_REALES = [];

function abrirFormularioNNA() {
  // Limpiar campos del formulario
  document.getElementById('f-nna-nombre').value  = '';
  document.getElementById('f-tutor-nombre').value = '';
  document.getElementById('f-tutor-curp').value   = '';
  document.getElementById('f-tutor-tel').value    = '';
  document.getElementById('f-hecho-madre').value  = '';
  document.getElementById('f-hecho-fecha').value  = '';
  document.getElementById('f-hecho-exp').value    = '';

  // Resetear buscador CIE-10
  cie10Limpiar();
  document.getElementById('cie10-results').classList.remove('show');

  // Solo cargar el catálogo de delitos (CIE-10 es bajo demanda)
  cargarCatalogosNNA();

  openModal('modal-alta-nna');
}

async function cargarCatalogosNNA() {
  try {
    const [resDel, resLng, resEst] = await Promise.all([
      apiFetch('/catalogos/delitos'),
      apiFetch('/catalogos/lenguas'),
      apiFetch('/catalogos/estados'),
    ]);

    if (resDel && resDel.ok) {
      const data = await resDel.json();
      const sel = document.getElementById('f-hecho-delito');
      sel.innerHTML = '<option value="">-- Seleccione un Delito --</option>';
      data.forEach(d => { sel.innerHTML += `<option value="${d}">${d}</option>`; });
    }

    if (resLng && resLng.ok) {
      const data = await resLng.json();
      const sel = document.getElementById('f-nna-lengua');
      sel.innerHTML = '<option value="">-- Seleccione Lengua --</option>';
      data.forEach(l => {
        sel.innerHTML += `<option value="${l.id}">${l.nombre}${l.es_indigena ? '' : ''}</option>`;
      });
    }

    if (resEst && resEst.ok) {
      const data = await resEst.json();
      const sel = document.getElementById('f-nna-estado');
      sel.innerHTML = '<option value="">-- Seleccione Estado --</option>';
      data.forEach(e => { sel.innerHTML += `<option value="${e.id}">${e.nombre}</option>`; });
    }
  } catch (e) { console.error("Error cargando catálogos NNA", e); }
}

async function cargarMunicipios(idEstado) {
  const sel = document.getElementById('f-nna-municipio');
  sel.innerHTML = '<option value="">-- Cargando... --</option>';
  sel.disabled = true;
  if (!idEstado) {
    sel.innerHTML = '<option value="">-- Seleccione primero un Estado --</option>';
    return;
  }
  try {
    const res = await apiFetch(`/catalogos/municipios/${idEstado}`);
    if (res && res.ok) {
      const data = await res.json();
      sel.innerHTML = '<option value="">-- Seleccione Municipio --</option>';
      data.forEach(m => { sel.innerHTML += `<option value="${m.id}">${m.nombre}</option>`; });
      sel.disabled = false;
    }
  } catch (e) { console.error("Error cargando municipios", e); }
}

async function cargarExpedientes() {
  const res = await apiFetch('/expedientes');
  if (!res) return;
  EXPEDIENTES_REALES = await res.json();
  renderTablaNNA();
}

