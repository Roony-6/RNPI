async function guardarExpediente() {
  const curpTutor = document.getElementById('f-tutor-curp').value.toUpperCase();
  if (!curpTutor || curpTutor.length < 10) { toast('La CURP del tutor es obligatoria', 'error'); return; }

  const lenguaVal    = document.getElementById('f-nna-lengua').value;
  const municipioVal = document.getElementById('f-nna-municipio').value;
  const body = {
    nna_nombre:          document.getElementById('f-nna-nombre').value,
    tutor_nombre:        document.getElementById('f-tutor-nombre').value,
    tutor_curp:          curpTutor,
    tutor_telefono:      document.getElementById('f-tutor-tel').value,
    cie10_codigo:        document.getElementById('f-tutor-cie10').value,
    victima_madre:       document.getElementById('f-hecho-madre').value,
    fecha_hecho:         document.getElementById('f-hecho-fecha').value,
    expediente_juridico: document.getElementById('f-hecho-exp').value,
    delito:              document.getElementById('f-hecho-delito').value,
    lengua_id:           lenguaVal    ? parseInt(lenguaVal)    : null,
    municipio_id:        municipioVal ? parseInt(municipioVal) : null,
  };

  try {
    const res = await apiFetch('/expedientes', { method: 'POST', body: JSON.stringify(body) });
    if (!res.ok) throw new Error("Error al guardar");
    toast('Expediente Integral almacenado en BD', 'success');
    closeModal('modal-alta-nna');
    cargarExpedientes();
  } catch(e) { toast('Error al conectar con la BD', 'error'); }
}

function verDetalleNNA(index) {
  const d = EXPEDIENTES_REALES[index];
  document.getElementById('det-nna-nombre').innerText    = d.nombre;
  document.getElementById('det-nna-curp').innerText      = d.curp;
  document.getElementById('det-nna-fecha').innerText     = d.fecha_nac;
  document.getElementById('det-nna-idioma').innerText    = d.idioma;
  document.getElementById('det-nna-localidad').innerText = d.localidad || 'No especificada';
  document.getElementById('det-tutor-nombre').innerText = d.tutor.nombre;
  document.getElementById('det-tutor-tel').innerText   = d.tutor.telefono;
  document.getElementById('det-tutor-salud').innerText = d.tutor.cie10;
  document.getElementById('det-hecho-exp').innerText   = d.hecho.exp;
  document.getElementById('det-hecho-delito').innerText = d.hecho.delito;
  document.getElementById('det-hecho-madre').innerText = d.hecho.madre;
  openModal('modal-detalle-nna');
}

function confirmarEliminarNNA(index) {
  mostrarConfirm({
    icon: 'danger', title: 'Eliminar Expediente',
    message: `¿Está seguro de eliminar este expediente? Esta acción borrará todo su historial en el sistema de demostración.`,
    btnClass: 'btn-danger', btnText: 'Eliminar Expediente',
    callback: () => {
      EXPEDIENTES_REALES.splice(index, 1);
      toast('Expediente NNA eliminado exitosamente', 'success');
      closeModal('confirm-modal-overlay');
      renderTablaNNA();
    }
  });
}


